# Telegram API credentials (from my.telegram.org)
API_ID=12345678
API_HASH=#your api hash

# Bot token (from @BotFather)
BOT_TOKEN= #123456:ABCDEF-your-bot-token-here

# Bot username (without changing @ format)
ELITE_BOT_USERNAME= #@YourBotUsername

# Elite session string
# Generate using @elite_session_maker_bot
ELITE_SESSION= #your_elite_string_session_here

# Sudo users (Telegram user IDs, comma-separated)
SUDO_USERS=5470956337

# Alive name
ALIVE_NAME=Rishabh # Your name 

# Log chat ID (private group/channel ID, usually starts with -100)
LOG_CHAT_ID= #-1001234567890
# branch for updating bot
BRANCH=elite
